# Neon PostgreSQL connection strings.
# Runtime (pooled) — used by the Neon serverless driver adapter.
DATABASE_URL="postgresql://USER:PASSWORD@HOST-pooler.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"

# Migrations (direct, unpooled) — used by `prisma migrate`.
DIRECT_URL="postgresql://USER:PASSWORD@HOST.REGION.aws.neon.tech/DB?sslmode=require&channel_binding=require"

# NextAuth v5. Generate AUTH_SECRET with `npx auth@beta secret` or `openssl rand -base64 32`.
AUTH_SECRET=""
AUTH_GITHUB_ID=""
AUTH_GITHUB_SECRET=""

# Resend (email). Get your API key from https://resend.com/api-keys
RESEND_API_KEY=""
# From address for transactional emails. Must be a verified Resend domain sender.
# Use "onboarding@resend.dev" for testing (only delivers to your Resend account email).
RESEND_FROM_EMAIL="onboarding@resend.dev"
